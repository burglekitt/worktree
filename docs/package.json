{
  "name": "docs",
  "private": true,
  "description": "",
  "main": "index.js",
  "scripts": {
    "predev": "node ../bin/sync-docs-version.mjs",
    "dev": "next dev --turbopack",
    "dev:with-worker": "pnpm run worker:build && pnpm run worker:setup-dev-vars && concurrently -k -r -n watch,worker,docs \"pnpm run worker:build:watch\" \"pnpm run worker:dev:serve\" \"pnpm run dev\"",
    "worker:build:watch": "cd infra/cloudflare-worker && tsup worker.ts --watch",
    "worker:dev:serve": "wrangler dev infra/cloudflare-worker/dist/worker.js --local --config infra/cloudflare-worker/wrangler.toml",
    "worker:setup-dev-vars": "node scripts/setup-dev-vars.mjs",
    "worker:build-context": "node scripts/build-context.mjs",
    "worker:build": "pnpm run worker:build-context && cd infra/cloudflare-worker && tsup worker.ts",
    "worker:deploy": "pnpm run worker:build && wrangler deploy --config infra/cloudflare-worker/wrangler.toml",
    "prebuild": "node ../bin/sync-docs-version.mjs",
    "build": "next build",
    "postbuild": "pagefind --site .next/server/app --output-path out/_pagefind",
    "test": "vitest run"
  },
  "keywords": [],
  "author": "",
  "license": "ISC",
  "packageManager": "pnpm@10.32.1",
  "dependencies": {
    "@base-ui/react": "^1.3.0",
    "@heroicons/react": "^2.2.0",
    "@tailwindcss/postcss": "^4.2.2",
    "@tailwindcss/vite": "^4.2.2",
    "@tanstack/ai": "^0.10.0",
    "@tanstack/ai-gemini": "^0.8.5",
    "@tanstack/ai-react": "^0.7.8",
    "@tanstack/react-form": "^1.28.5",
    "@tanstack/react-form-devtools": "^0.2.19",
    "@tanstack/react-query": "^5.95.2",
    "@tanstack/react-store": "^0.9.3",
    "next": "^16.1.6",
    "nextra": "^4.6.1",
    "nextra-theme-docs": "^4.6.1",
    "postcss": "^8.5.8",
    "react": "^19.2.4",
    "react-dom": "^19.2.4",
    "tailwindcss": "^4.2.2"
  },
  "devDependencies": {
    "concurrently": "^8.2.0",
    "@testing-library/jest-dom": "^6.8.0",
    "@testing-library/react": "^16.3.0",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.1.9",
    "jsdom": "^26.1.0",
    "pagefind": "^1.4.0",
    "vitest": "^4.0.18",
    "wrangler": "^4.79.0",
    "tsup": "^8.0.1"
  }
}
