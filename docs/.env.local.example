# docs/.env.local.example
# Copy this file to .env.local and fill in your values.
# .env.local is gitignored — never commit actual secrets.

# Your Google Gemini API key (free tier at aistudio.google.com)
GEMINI_API_KEY=

# URL of the deployed Cloudflare Worker (set for production builds).
# For local dev this defaults to http://localhost:8787 — no need to set it here.
NEXT_PUBLIC_GEMINI_WORKER_URL=https://worktree-gemini-proxy.<your-subdomain>.workers.dev
