{
  "name": "@burglekitt/worktree",
  "version": "0.1.0",
  "description": "A CLI tool for managing git worktrees with enhanced workflow features",
  "main": "./bin/run.js",
  "type": "module",
  "scripts": {
    "build": "shx rm -rf dist && tsc -b",
    "test": "vitest run",
    "typecheck": "tsc --noEmit",
    "format": "biome format",
    "format:fix": "biome format --write",
    "lint": "biome lint",
    "lint:fix": "biome lint --write"
  },
  "files": [
    "dist",
    "bin",
    "README.md"
  ],
  "keywords": [
    "git",
    "worktree",
    "cli",
    "workflow"
  ],
  "repository": {
    "type": "git",
    "url": "https://github.com/burglekitt/worktree.git"
  },
  "homepage": "https://github.com/burglekitt/worktree",
  "license": "MIT",
  "packageManager": "pnpm@10.32.1+sha512.a706938f0e89ac1456b6563eab4edf1d1faf3368d1191fc5c59790e96dc918e4456ab2e67d613de1043d2e8c81f87303e6b40d4ffeca9df15ef1ad567348f2be",
  "bin": {
    "worktree": "./bin/run.js",
    "@burglekitt/worktree": "./bin/run.js"
  },
  "oclif": {
    "bin": "worktree",
    "commands": "./dist/commands",
    "dirname": "worktree",
    "topicSeparator": " "
  },
  "dependencies": {
    "@inquirer/prompts": "^8.3.0",
    "@oclif/core": "^4.8.3",
    "chalk": "^5.6.2",
    "glob": "^13.0.6",
    "ora": "^9.3.0"
  },
  "devDependencies": {
    "@biomejs/biome": "2.4.6",
    "@oclif/test": "^4.1.16",
    "@types/node": "^18.19.130",
    "shx": "^0.4.0",
    "ts-node": "^10.9.2",
    "typescript": "^5.9.3",
    "vitest": "^4.0.18"
  }
}
